#cloud-config
hostname: ${hostname}
fqdn: ${hostname}.cloud.local
manage_etc_hosts: true

users:
  - name: cloud
    sudo: ALL=(ALL) NOPASSWD:ALL
    groups: sudo
    shell: /bin/bash
    ssh_authorized_keys:
      - ${ssh_key}

packages:
  - qemu-guest-agent
  - python3

runcmd:
  - systemctl enable --now qemu-guest-agent